# Public domain — set in Dokploy's Environment tab. Traefik routes
# traffic based on this Host header. Must have a DNS A record pointing
# at your Dokploy ingress IP.
#
# Both the registry API (/v2/*) and the admin UI (/) live on this
# single domain. Docker clients push/pull to <REGISTRY_DOMAIN> and
# browsers load the UI from the same hostname.
REGISTRY_DOMAIN=registry.yourdomain.com

# Admin credentials for docker login and the web UI. Generated into a
# bcrypt htpasswd file on first boot and persisted in the registry-auth
# volume. To rotate the password, update it here, remove the volume on
# the Dokploy host (`docker volume rm <stack>_registry-auth`), and
# redeploy — the init container will recreate htpasswd.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-something-strong

# --- Optional retention tuning ---------------------------------------------
# How many tags to keep per repository. Older tags (version-sorted
# descending) are deleted on each retention cycle.
# KEEP_LAST=10

# Seconds between retention cycles. Default: 86400 (24h).
# RETENTION_INTERVAL_SECONDS=86400
